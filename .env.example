# Copy this file to .env and fill in real values.
# NEVER commit .env — it is already in .gitignore.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=9000
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be >= 32 random characters. NOT "your-secret-key".
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ── Cookie ────────────────────────────────────────────────────────────────────
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local replica set (docker-compose) — credentials must match MONGO_ADMIN_* below.
# 3 data-bearing voting nodes (PSS), no arbiter — see
# docs/runbooks/mongodb-replica-set.md for why (NEW#4 in
# production-readiness-audit-2026-07-22.md: an arbiter can never
# acknowledge write concern "majority", so a 2-data+1-arbiter set stalls
# every majority write the moment either data node is lost).
MONGODB_URI=mongodb://${MONGO_ADMIN_USER}:${MONGO_ADMIN_PASS}@mongo1:27017,mongo2:27017,mongo3:27017/ticket-be?replicaSet=rs0&authSource=admin
# Atlas production: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>
# (Atlas M10+ replica sets are already 3 data-bearing nodes by default —
# this repo's local topology intentionally mirrors that for dev/prod parity.)

# Local Docker MongoDB credentials (used by docker-compose + mongo-init.sh)
# Change MONGO_ADMIN_PASS from the default before any public deployment.
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASS=devMongoPass123

# ── Redis ─────────────────────────────────────────────────────────────────────
# Three independent Redis roles — each MUST be its own physical instance in
# production, so an outage in one never takes down the other two:
#   - cache:    general-purpose app cache ONLY. volatile-lru — keys can be
#               evicted under memory pressure, so nothing security-critical
#               may live here (production-readiness-audit-2026-07-22.md PRE-1).
#   - queue:    BullMQ job processing ONLY. noeviction.
#   - security: JWT blacklist / session-revocation data ONLY. noeviction.
#               A dedicated host+port is REQUIRED in production — validated by
#               env.validation.ts and re-checked by RedisSecurityService itself
#               (defense-in-depth). Reusing the queue's host+port here would
#               collapse authentication and BullMQ into a single failure
#               domain (production-readiness-audit-2026-07-23.md).

# cache: general-purpose app cache only
REDIS_HOST=redis-cache
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
# REDIS_DB=0

# queue: BullMQ only
REDIS_QUEUE_HOST=redis-queue
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_PASSWORD=REPLACE_WITH_REDIS_QUEUE_PASSWORD
# REDIS_QUEUE_DB=0

# security: JWT blacklist / session-revocation only — REQUIRED in production,
# and must not share a host+port with either REDIS_HOST or REDIS_QUEUE_HOST
# above. Outside production, if unset, RedisSecurityService falls back to
# REDIS_QUEUE_* then REDIS_HOST/PORT and logs a warning identifying the
# fallback tier used — this fallback is refused entirely in production.
REDIS_SECURITY_HOST=redis-security
REDIS_SECURITY_PORT=6379
REDIS_SECURITY_PASSWORD=REPLACE_WITH_REDIS_SECURITY_PASSWORD
# REDIS_SECURITY_DB=0
# Set to "true" when REDIS_SECURITY_HOST is a managed/hosted provider that
# requires TLS on the standard Redis port (e.g. Upstash). Leave unset for
# self-hosted plain-TCP instances (local Docker/docker-compose).
# REDIS_SECURITY_TLS=true

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:9000/api/v1/auth/google/callback

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_API_SECRET

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Set to "true" in production to restrict /payment/webhook to Stripe's published IPs
STRIPE_IP_ALLOWLIST=false

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=REPLACE_WITH_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_PAYPAL_CLIENT_SECRET

# ── Currency ─────────────────────────────────────────────────────────────────
VND_TO_USD_RATE=26000

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Swagger ───────────────────────────────────────────────────────────────────
# Disabled in all environments unless explicitly set to "true".
# Only enable on local dev or internal staging — NEVER expose on public production.
# NOTE: When NODE_ENV=production, Swagger is ALWAYS disabled regardless of this setting.
SWAGGER_ENABLED=false

# ── Observability ─────────────────────────────────────────────────────────────
# Log verbosity: error | warn | info | http | verbose | debug
# Default: "info" in production, "debug" in all other environments.
# Change at runtime without redeployment by updating the env var and restarting.
LOG_LEVEL=info

# Secret for GET /internal/metrics endpoint (heap, RSS, CPU stats).
# Leave unset to disable the endpoint entirely.
INTERNAL_METRICS_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── Deployment (used by cd.yml) ────────────────────────────────────────────────
# Webhook URL that cd.yml POSTs to trigger a deploy (optional)
DEPLOY_WEBHOOK_URL=
DEPLOY_WEBHOOK_TOKEN=
# Base URL used by cd.yml to health-check the deployment (optional)
PRODUCTION_HEALTH_URL=http://localhost:9000

# ── Alerting ─────────────────────────────────────────────────────────────────
# Slack incoming webhook URL for CI/CD and backup failure notifications (optional)
SLACK_ALERT_WEBHOOK=

# REQUIRED for production: email address that receives critical alerts.
# Refund failures, payment anomalies, and other money-risk events are emailed here.
# If unset, failures are only logged (not emailed).
ALERT_EMAIL=ops-team@example.com
