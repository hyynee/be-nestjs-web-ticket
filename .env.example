# Copy this file to .env and fill in real values.
# NEVER commit .env — it is already in .gitignore.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=9000
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be >= 32 random characters. NOT "your-secret-key".
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ── Cookie ────────────────────────────────────────────────────────────────────
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local replica set (docker-compose) — credentials must match MONGO_ADMIN_* below:
MONGODB_URI=mongodb://${MONGO_ADMIN_USER}:${MONGO_ADMIN_PASS}@mongo1:27017,mongo2:27017,mongo-arbiter:27017/ticket-be?replicaSet=rs0&authSource=admin
# Atlas production: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>

# Local Docker MongoDB credentials (used by docker-compose + mongo-init.sh)
# Change MONGO_ADMIN_PASS from the default before any public deployment.
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASS=devMongoPass123

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis-cache
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
# REDIS_DB=0
REDIS_QUEUE_HOST=redis-queue
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_PASSWORD=REPLACE_WITH_REDIS_QUEUE_PASSWORD
# REDIS_QUEUE_DB=0

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:9000/api/v1/auth/google/callback

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_API_SECRET

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Set to "true" in production to restrict /payment/webhook to Stripe's published IPs
STRIPE_IP_ALLOWLIST=false

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=REPLACE_WITH_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_PAYPAL_CLIENT_SECRET

# ── Currency ─────────────────────────────────────────────────────────────────
VND_TO_USD_RATE=26000

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Swagger ───────────────────────────────────────────────────────────────────
# Disabled in all environments unless explicitly set to "true".
# Only enable on local dev or internal staging — NEVER expose on public production.
# NOTE: When NODE_ENV=production, Swagger is ALWAYS disabled regardless of this setting.
SWAGGER_ENABLED=false

# ── Observability ─────────────────────────────────────────────────────────────
# Log verbosity: error | warn | info | http | verbose | debug
# Default: "info" in production, "debug" in all other environments.
# Change at runtime without redeployment by updating the env var and restarting.
LOG_LEVEL=info

# Secret for GET /internal/metrics endpoint (heap, RSS, CPU stats).
# Leave unset to disable the endpoint entirely.
INTERNAL_METRICS_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── Deployment (used by cd.yml) ────────────────────────────────────────────────
# Webhook URL that cd.yml POSTs to trigger a deploy (optional)
DEPLOY_WEBHOOK_URL=
DEPLOY_WEBHOOK_TOKEN=
# Base URL used by cd.yml to health-check the deployment (optional)
PRODUCTION_HEALTH_URL=http://localhost:9000

# ── Alerting ─────────────────────────────────────────────────────────────────
# Slack incoming webhook URL for CI/CD and backup failure notifications (optional)
SLACK_ALERT_WEBHOOK=

# REQUIRED for production: email address that receives critical alerts.
# Refund failures, payment anomalies, and other money-risk events are emailed here.
# If unset, failures are only logged (not emailed).
ALERT_EMAIL=ops-team@example.com


docker compose exec mongo1 mongosh --quiet --eval '
rs.initiate({
  _id: "rs0",
  members: [
    { _id: 0, host: "mongo1:27017", priority: 2 },
    { _id: 1, host: "mongo2:27017", priority: 1 },
    { _id: 2, host: "mongo-arbiter:27017", arbiterOnly: true }
  ]
})
'
{ ok: 1 }

db.getSiblingDB("admin").createUser({
  user: "admin",
  pwd: "adminpassword",
  roles: [ { role: "root", db: "admin" } ]
})
